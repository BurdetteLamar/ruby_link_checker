#!/usr/bin/env ruby

require 'optparse'
require_relative '../lib/ruby_link_checker'
require_relative '../lib/ruby_link_checker/version'

parser = OptionParser.new

parser.banner = <<-EOF

Usage: #{$0} [options]

  - Reads Ruby HTML documentation found at the given source.

  - Writes a JSON "stash" file containing its findings.
  - Writes an HTML report file that lists:

    - Onsite pages found.
    - Broken links in onsite pages (including both pages not found and fragments not found).
    - Offsite pages found.

  The link checker creates a new subdirectory in directory ./ruby_link_checker
  whose name is timestamp-based (e/g/. 2026-02-11-Wed-21.29.00+0000),
  and writes output files stash.json and report.html into that subdirectory.

Options

EOF

options = {
  source: 'master',
  open_report: false,
  report_only: false,
  github_lines: false,
  legal: false,
  news: false,
  verbosity: 'moderate',
  no_op: false,
}

parser.on(
  '--source=SOURCE',
  'Specify the location of the documentation to check;',
  "  defaults to #{File.join(RubyLinkChecker::BASE_URL, 'master', 'index.html')};",
  '  otherwise must be one of:',
  '  - Version (e.g., "4.0") of the Ruby documentation to be read;',
  "    see versions at #{RubyLinkChecker::BASE_URL}.",
  '    The first page to be read will be',
  "    #{File.join(RubyLinkChecker::BASE_URL, '<version>', 'index.html')}.",
  '  - URL of the first page to be read.',
  '  - File path of the first page to be read.'
) do |arg|
  options[:source] = arg
end

parser.on(
  '--open-report',
  'Open the generated HTML report in a web browser.'
) do
  options[:open_report] = true
end

parser.on(
  '--report-only',
  'Create a new HTML report based on the most recent stash file;',
  '  do not re-read the Ruby documents or write a new stash file.',
  '  This may be useful when developing or debugging the reporting code',
  '  (avoids repeating the long reading and stashing process).'
) do
  options[:report_only] = true
end

  parser.on(
  '--github-lines',
  'Do not check line-number fragments on GitHub pages (e.g., #L14-L22),',
  '  because there is no such id on the page (GitHub has special handling).'
  )  do |arg|
  options[:github_lines] = true
  end

parser.on(
  '--legal',
  'Check paths and fragments on LEGAL pages.',
  '  By default, these are reported, but not checked.',
  '  This is because the Ruby core team has determined',
  '  that the LEGAL page is historical in nature and should not be modified.'
  ) do
  options[:legal] = true
end

parser.on(
  '--news',
  'Check paths and fragments for links on NEWS pages.',
  '  By default, these are reported, but not checked.',
  '  This is because the Ruby core team has determined',
  '  that the NEWS pages are historical in nature and should not be modified.'
  ) do
  options[:news] = true
end

parser.on(
  '--verbosity=SETTING',
  'Set verbosity to one of:',
  '  quiet: Print no progress messages.',
  '  minimal: Print only large-scale progress messages.',
  '  moderate: (default) Print more progress messages.',
  '  debug: Print all progress messages.'
) do |arg|
  RubyLinkChecker.validate_verbosity(arg)
  options[:verbosity] = arg
end

parser.on(
  '--no-op',
  'Do not read documentation or write reports,',
  '  but print as much information as possible.',
) do |arg|
  options[:no_op] = true
end

parser.on(
  '--version',
  'Print the version and exit.',
) do
  puts RubyLinkChecker::VERSION
  exit
end

parser.parse!

RubyLinkChecker.new({}, {}, options)